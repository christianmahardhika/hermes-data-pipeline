# Hermes Data Pipeline - Environment Variables

# ============================================
# SHARED SERVICES
# ============================================

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_GRPC_URL=http://localhost:6334

# TEI Embeddings
TEI_URL=http://localhost:8082

# Kiromania LLM Gateway
LABELER_BASE_URL=http://localhost:9000/v1
LABELER_API_KEY=your-api-key-here
LABELER_MODEL=claude-sonnet-4
KIRO_API_KEY=your-api-key-here
KIRO_URL=http://localhost:9000

# ============================================
# NEWS SOCIAL INTELLIGENCE PIPELINE
# ============================================

# SQLite staging database
NEWS_DB_PATH=./news_staging.db

# Batch processing
NEWS_BATCH_SIZE=20
NEWS_DAEMON_INTERVAL=15m

# ============================================
# MARKET DATA PIPELINE
# ============================================

# Yahoo Finance (free, no key needed)
# ALPHA_VANTAGE_API_KEY=your-key-here
# POLYGON_API_KEY=your-key-here

# Symbols to track
IDX_SYMBOLS=BBRI.JK,BMRI.JK,BBNI.JK,TLKM.JK
FOREX_PAIRS=USDIDR=X,EURUSD=X

# ============================================
# SOCIAL MEDIA PIPELINE
# ============================================

# X/Twitter (via xurl CLI - configure separately)
# X_AUTH_TOKEN=your-token

# Reddit API
# REDDIT_CLIENT_ID=your-client-id
# REDDIT_CLIENT_SECRET=your-secret
# REDDIT_USER_AGENT=hermes-pipeline/1.0

# Subreddits to monitor
REDDIT_SUBREDDITS=indonesia,finansial,stocks

# ============================================
# KNOWLEDGE INGESTION PIPELINE
# ============================================

# Chunking settings
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Default collection
DEFAULT_COLLECTION=pagupon-kb

# ============================================
# OPTIONAL SERVICES (docker-compose --profile full)
# ============================================

# PostgreSQL
POSTGRES_USER=hermes
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hermes_pipelines

# Redis
REDIS_URL=redis://localhost:6379
