# Enhanced IDX Analyst — Environment Variables Template
# DO NOT commit actual values — copy to .env and fill in locally

# Notion API
NOTION_API_KEY=your_notion_api_key_here

# Portfolio Configuration
PORTFOLIO_VALUE=279100000  # Your portfolio value in IDR

# Memory & Logging
MEMORY_DIR=~/.hermes/profiles/pagupon-finance/memory

# LLM Provider (if using real LLM for debate)
LLM_PROVIDER=kiro  # kiro, openai, anthropic, etc.
LLM_API_KEY=your_llm_key_here

# Optional: Market Data APIs
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
YFINANCE_PREMIUM_KEY=your_yfinance_key

# Optional: Risk Management
MAX_POSITION_SIZE_PCT=0.05
MAX_DRAWDOWN=0.10
